{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api|assets|favicon\\.svg|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
